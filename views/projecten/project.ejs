<%- include('../includes/header.ejs') %>
<div class="container mt-4 align-items-center project">
    <div class="row">
        <div class="col text-start">
            <h1 class="display-4">
                <%= data.title %>
            </h1>
            <div class="mt-3">
                <% data.tech.forEach(tech=> { %>
                    <a href="/projecten?&filter=<%= tech %>" class="badge rounded-pill bg-secondary me-1 tech fs-6">
                        <%= tech %>
                    </a>
                    <% }) %>
            </div>
            <div class="my-4" id="description" url="/projecten/api/<%= project %>/<%= data.longHtml %>"></div>
            <div class="mt-2 mb-4">
                <% data.links.forEach(link=> { %>
                    <a class="btn big-btn btn-primary fs-5" href="<%= link.url %>" target="_blank">
                        <%= link.name %>
                    </a>
                    <% }) %>
            </div>
        </div>
        <div class="col d-flex flex-column align-items-end" id="project-images">
            <% data.images.forEach(img=> { %>
                <div class="card" style="width: 75%;">
                    <img src="/projecten/api/<%= project %>/<%= img.url %>" id="project-image" class="card-img-top"
                        alt="<%= img.description %>">
                    <% if (img.description && img.description.trim() !=="" ) { %>
                        <div class="card-body text-start">
                            <p class="card-text">
                                <%= img.description %>
                            </p>
                        </div>
                        <% } %>
                </div>
                <% }) %>
        </div>
    </div>
</div>
<script src="/js/project.js"></script>
<%- include('../includes/footer.ejs') %>