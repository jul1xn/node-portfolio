<%- include('../includes/header.ejs') %>
<div class="container mt-4 align-items-center">
    <div class="row">
        <a class="text-center display-5 projecten-title" href="/projecten">Projecten</a>
        <div class="mt-3 mb-4 d-flex justify-content-center flex-wrap tech-list">
            <% available_tech.forEach(tech => { %>
                <% if (filter && filter.toLowerCase() === tech.toLowerCase()) { %>
                    <a href="/projecten?page=<%= current_page %>&filter=<%= tech %>" class="btn btn-sm btn-secondary me-1 mb-1">
                        <%= tech %>
                    </a>
                <% } else { %>
                    <a href="/projecten?page=<%= current_page %>&filter=<%= tech %>" class="btn btn-sm btn-outline-secondary me-1 mb-1">
                        <%= tech %>
                    </a>
                <% } %>
            <% }) %>
        </div>
    </div>
    <div class="row mt-2 d-flex justify-content-center">
        <div class="container d-flex align-items-center justify-content-center" id="projecten-container">
            <!-- Projecten zullen hier dynamisch worden geladen -->
        </div>
    </div>
    <div class="row mt-4 d-flex justify-content-center">
        <nav aria-label="...">
            <ul class="pagination justify-content-center" id="pagination">
            </ul>
        </nav>
    </div>
</div>
<script src="/js/projecten.js"></script>
<%- include('../includes/footer.ejs') %>